# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=paper                     # paper | live  (live requires 2nd-admin approval to switch)
APP_VERSION=1.0.0
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string
TIMEZONE=Asia/Kolkata

# ─── API / Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-too
JWT_EXPIRY_HOURS=8
JWT_REFRESH_DAYS=7
TOTP_ISSUER=ThetaGainers
IP_ALLOWLIST=                     # CSV of CIDRs, empty = all (dev only)
BCRYPT_ROUNDS=12

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://navin:navin@localhost:5432/navin_algo
REDIS_URL=redis://localhost:6379/0

# ─── SEBI & Exchange compliance (hard caps, cannot be raised via UI) ────────
SEBI_ALGO_ID=                     # assigned by broker when registered; required in live mode
ORDERS_PER_SEC_PER_USER=8         # SEBI non-institutional threshold is 10; we cap at 8
ORDERS_PER_SEC_GLOBAL=20          # firm-wide
OTR_HALT_THRESHOLD=100            # order-to-trade ratio; halt at this value
NIFTY_FREEZE_QTY=1800             # NSE freeze qty per order — re-verify each expiry
SENSEX_FREEZE_QTY=1000            # BSE freeze qty per order — re-verify each expiry
NIFTY_LOT_SIZE=65                 # verified from security master at runtime (NSE 2026 update)
SENSEX_LOT_SIZE=20                # verified from security master at runtime
ICEBERG_SLICE_JITTER_MS=100       # gap between sliced child orders

# ─── Risk caps (cannot be raised via UI; editable by Admin via Settings) ────
MAX_LOTS_PER_STRATEGY=10
MAX_ACTIVE_STRATEGIES_PER_USER=5
MAX_ACTIVE_STRATEGIES_GLOBAL=25
MAX_DAILY_LOSS_PER_USER=50000     # ₹
MAX_DAILY_LOSS_GLOBAL=500000      # ₹
CIRCUIT_BREAKER_ERROR_THRESHOLD=3
COOLING_OFF_MINUTES_AFTER_HALT=30
DEAD_MAN_SWITCH_SECONDS=120       # UI heartbeat timeout
MTM_DRAWDOWN_KILL_PCT=40          # halt strategy if DD from peak > this %
TWO_PERSON_APPROVAL_MIN_LOTS=5    # actions above this need 2nd admin approval
HEDGE_LEGS_DEFAULT_ON=false       # naked straddle default; operator opts in to hedges

# ─── Brokers (keys loaded per-broker from AWS Secrets Manager in prod) ──────
BROKER_ENABLED=paper,axis,zerodha,monarch,jm
# Axis Direct RAPID
AXIS_CLIENT_ID=
AXIS_AUTH_KEY=
AXIS_API_BASE=https://api.axisdirect.in
# Zerodha Kite Connect
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
# Monarch Networth (SuperTrader / API)
MONARCH_API_KEY=
MONARCH_API_SECRET=
# JM Financial (Blink API)
JM_API_KEY=
JM_API_SECRET=

# ─── Notifications ──────────────────────────────────────────────────────────
GUPSHUP_API_KEY=
GUPSHUP_SOURCE=
TELEGRAM_BOT_TOKEN=
AWS_SES_REGION=ap-south-1
AWS_SES_FROM=alerts@thetagainers.in
TWILIO_ACCOUNT_SID=               # for SMS + voice-call on critical
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── AWS (production) ───────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET_BACKUPS=theta-gainers-backups
S3_BUCKET_AUDIT_ANCHORS=theta-gainers-audit
SENTRY_DSN=
CLOUDWATCH_LOG_GROUP=/theta-gainers/prod
